<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Определяем переменную LOG_LEVEL.
         Если системное свойство 'log.level' не задано, используется значение 'INFO'. -->
    <property name="LOG_LEVEL" value="${log.level:-INFO}" />
    <property name="LOG_FILE" value="${log.file:-logs/timeindustry.log}" /> <!-- Переменная для пути к файлу лога -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[%level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Для вывода в файл -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- ежедневная ротация -->
            <fileNamePattern>logs/timeindustry.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- храним логи 30 дней -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>


    <!-- Уровень логирования теперь берётся из переменной -->
    <root level="${LOG_LEVEL}">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
</configuration>